# -----------------------------------------------------------
# Slack Bot Token  (starts with xoxb-)
# Get this from: api.slack.com -> Your App -> OAuth & Permissions
# -----------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# -----------------------------------------------------------
# Channel to post announcements in
# -----------------------------------------------------------
SLACK_CHANNEL=#new-hires

# -----------------------------------------------------------
# Webhook secret - any string you choose.
# Pass it as "secret" in the POST body to authenticate calls.
# Leave blank to disable auth (not recommended in production).
# -----------------------------------------------------------
WEBHOOK_SECRET=change-me-to-something-secret

# -----------------------------------------------------------
# Port (optional, defaults to 3000)
# -----------------------------------------------------------
PORT=3000
